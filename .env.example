# ============================================================
#  PRAKRITI HERBS CRM - Environment Variables
#  Copy this file to ".env" and fill REAL values.
#  NEVER commit .env to git (already in .gitignore).
# ============================================================

# ---- Database (PostgreSQL) ----
DATABASE_URL="postgresql://prakriti_user:CHANGE_ME@localhost:5432/prakriti_crm?schema=public"

# ---- JWT Auth (generate long random strings) ----
JWT_SECRET="CHANGE_ME_to_a_long_random_secret_min_32_chars"
JWT_REFRESH_SECRET="CHANGE_ME_to_another_long_random_secret"
JWT_EXPIRES_IN="12h"

# ---- Redis (OPTIONAL - empty = in-memory fallback, fine for single server) ----
REDIS_URL=""

# ---- SHIPROCKET API (Shiprocket dashboard > Settings > API > Create API User) ----
SHIPROCKET_EMAIL="your-shiprocket-api-user@email.com"
SHIPROCKET_PASSWORD="your-shiprocket-api-password"
SHIPROCKET_BASE_URL="https://apiv2.shiprocket.in/v1/external"
SHIPROCKET_PICKUP_LOCATION="Primary"
SHIPROCKET_WEBHOOK_TOKEN=""

# ---- Default package dimensions ----
DEFAULT_PACKAGE_LENGTH="15"
DEFAULT_PACKAGE_BREADTH="12"
DEFAULT_PACKAGE_HEIGHT="6"
DEFAULT_PACKAGE_WEIGHT="0.5"
COMPANY_PINCODE="302012"

# ---- Super Admin seed (created by: npm run db:seed) ----
SUPERADMIN_NAME="Phogat"
SUPERADMIN_EMAIL="admin@amriayurveda.in"
SUPERADMIN_PASSWORD="ChangeThisOnFirstLogin@123"

# ---- Company details (invoice / label) ----
COMPANY_NAME="Amri Ayurveda"
COMPANY_GST="08AAQCP4095D1Z2"
COMPANY_PHONE="8968122246"

# ---- Order code prefix ----
ORDER_CODE_PREFIX="AACRM"